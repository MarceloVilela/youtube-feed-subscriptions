#
#
# SERVER
PORT=3334

#
#
# HEADLESS (false = abre browser visível, true = headless para CI)
HEADLESS=true

#
#
# TIMEOUT
TIMEOUT_SHORT=500
TIMEOUT_LONG=2500

#
#
# GOOGLE AUTH
G_USER=acc@gmail.com
G_PASS=
# USER é usado para nomes de arquivo no storage local/imgur
USER=acc@gmail.com

#
#
# STORAGE - IMAGE (debug|local|imgur)
# STORE_IMG, one of: debug|local|imgur
# about imgur - https://api.imgur.com/
STORE_IMG=imgur
IMGUR_CLIENT_ID=

#
#
# STORAGE - JSON
# STORE_JSON, one of: debug|local|jsonbin
# about jsonbin: https://jsonbin.io/api-reference/bins/get-started
STORE_JSON=jsonbin
JSONBIN_API_KEY=
JSONBIN_ID_STATE=
JSONBIN_ID_HOME=
JSONBIN_ID_SUBS=
JSONBIN_ID_CHANNEL=

#
# TASK - src/task.ts (opcional)
FEEDS=subscriptions
ITERATION_NUM=50
VIEWPORT_WIDTH=1920
VIEWPORT_HEIGHT=1080
CHANNEL_URL=https://www.youtube.com/c/VEVO